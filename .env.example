# --- APLICACIÓN ---
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_KEY=
APP_TIMEZONE=Europe/Madrid
APP_BUSINESS_TIMEZONE=Asia/Tokyo

# --- DOCKER COMPOSE ---
COMPOSE_PROFILES=dev,workers

# --- FEATURE FLAGS ---
FEATURE_OPS=0
FEATURE_BACKOFFICE=0
FEATURE_KEEPER=0

# --- DATABASE ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_ROOT_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# --- CACHE & SESSION (Redis) ---
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0
CACHE_TTL=3600
# Drivers de sesión y caché: 'redis' en producción (Railway), 'file'/'array' en local
SESSION_DRIVER=redis
CACHE_DRIVER=redis

# --- MAIL CONFIGURATION ---
MAIL_DRIVER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM=no-reply@komorebi.local
MAIL_FROM_ADDRESS=no-reply@komorebi.local
MAIL_FROM_NAME=Komorebi

# --- MCP / AI TOOLING ---
# Personal Access Token para el GitHub MCP Server (.vscode/mcp.json).
# Scopes mínimos: repo, read:org
# Genera uno en: https://github.com/settings/tokens
GITHUB_TOKEN=

# --- API INTEGRATIONS ---
# Open-Meteo (Free, no key required)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_CACHE_TTL=3600

# Nager.Date (Free, no key required)
NAGER_DATE_BASE_URL=https://date.nager.at/api/v3
NAGER_DATE_CACHE_TTL=86400

# --- TELEGRAM BOT (Optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=http://localhost:8080/api/v1/telegram/webhook

# --- SECURITY ---
# Generate with: php bin/generate-secrets.php
SESSION_SECRET=
CSRF_TOKEN_SECRET=
ENCRYPTION_KEY=
SESSION_NAME=KOMOREBI_SESSION
SESSION_LIFETIME=7200
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax
# Healthcheck token: detalles internos solo accesibles con X-Health-Token: <HEALTH_TOKEN>
HEALTH_TOKEN=
# CORS: orígenes permitidos para el hub Mercure (SSE). Separados por espacio.
# Ejemplo: https://komorebi.app https://www.komorebi.app
CORS_ALLOWED_ORIGINS=http://localhost:8080
# Mercure CORS: orígenes permitidos para suscribirse al hub SSE.
# En local: * (wildcard). En Railway: https://tu-app.up.railway.app
MERCURE_CORS_ORIGINS=*
# Proxy de confianza: si REMOTE_ADDR es esta IP, se lee X-Forwarded-For para rate limiting.
# Dejar vacío en local (sin proxy). En Railway: Railway internal IP.
TRUSTED_PROXY_IP=

# --- LOGGING ---
LOG_CHANNEL=single
LOG_LEVEL=debug
LOG_PATH=storage/logs/app.log
LOG_MAX_FILES=7

# --- PRODUCCIÓN / RAILWAY ---
APP_HTTPS=false
SKIP_COMPOSER=0
SKIP_MIGRATIONS=0
DB_SSL_CA=
# Workers supervisor (producción) — nº procesos por cola
QUEUE_EMAILS_PROCS=1
QUEUE_NOTIFICATIONS_PROCS=1
QUEUE_DEFAULT_PROCS=1

# --- OBSERVABILIDAD ---
SENTRY_DSN=
APP_VERSION=1.0.0

# --- CLOUDINARY ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
