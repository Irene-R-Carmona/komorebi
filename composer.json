{
  "name": "komorebi/cafe",
  "description": "Komorebi Café - V2",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "phpmailer/phpmailer": "^7.0",
    "ext-pdo": "*",
    "ext-mbstring": "*",
    "vlucas/phpdotenv": "^5.5",
    "ext-redis": "*",
    "ext-curl": "*",
    "ext-fileinfo": "*",
    "ext-gd": "*",
    "ext-zip": "*",
    "twbs/bootstrap-icons": "^1.11",
    "psr/container": "^2.0",
    "ext-iconv": "*",
    "monolog/monolog": "^3.0",
    "nyholm/psr7": "^1.8",
    "nyholm/psr7-server": "^1.1",
    "psr/http-server-middleware": "^1.0",
    "psr/http-server-handler": "^1.0",
    "psr/cache": "^3.0",
    "symfony/cache": "^8.0",
    "symfony/event-dispatcher": "^8.0",
    "ext-posix": "*",
    "ext-pcntl": "*",
    "ext-json": "*",
    "setasign/fpdf": "^1.8",
    "setasign/tfpdf": "^1.33",
    "chillerlan/php-qrcode": "^5.0",
    "php-di/php-di": "^7.0",
    "psr/simple-cache": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true
  },
  "require-dev": {
    "phpunit/phpunit": "^12",
    "phpstan/phpstan": "^1.12",
    "friendsofphp/php-cs-fixer": "^3.0",
    "vimeo/psalm": "^6.15",
    "squizlabs/php_codesniffer": "^4.0",
    "brianium/paratest": "^7.19",
    "phpstan/phpstan-phpunit": "*"
  },
  "scripts": {
    "test": "vendor/bin/phpunit --testdox",
    "test:coverage": "vendor/bin/phpunit --coverage-html tests/reports/coverage",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
    "analyse:psalm": "vendor/bin/psalm --show-info=true",
    "analyse:all": [
      "@analyse",
      "@analyse:psalm"
    ],
    "fix:cs": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php",
    "check:cs": "vendor/bin/phpcs",
    "check:cs-fixer": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff",
    "quality": "php bin/quality-check.php",
    "quality:fix": "php bin/quality-check.php --fix",
    "complexity": "php bin/analyze-complexity.php"
  }
}
