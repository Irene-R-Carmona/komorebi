{
  // ─── PHP Built-in Validator ───────────────────────────────────────────────
  // Desactivado: Intelephense provee diagnósticos PHP con su propio LSP.
  // El validador built-in requiere un ejecutable PHP local que no existe en
  // este proyecto (corre 100% en Docker).
  "php.validate.enable": false,
  // ─── Intelephense ─────────────────────────────────────────────────────────
  "intelephense.environment.phpVersion": "8.4",
  // ─── phpcs ────────────────────────────────────────────────────────────────
  // Nota: wongjn.php-sniffer no expande ${workspaceFolder}; usa path relativo
  // para que la extensión lo resuelva internamente via path.join(workspaceRoot, value).
  "phpcs.executablePath": "bin/phpcs.bat",
  // ─── PHPStan ──────────────────────────────────────────────────────────────
  "phpstan.executablePath": "bin/phpstan.bat",
  // ─── PHP CS Fixer ─────────────────────────────────────────────────────────
  "php-cs-fixer.executablePath": "bin/php-cs-fixer.bat",
  // ─── Psalm ────────────────────────────────────────────────────────────────
  "psalm.psalmScriptPath": "bin/psalm.bat",
  // ─── PHPUnit ──────────────────────────────────────────────────────────────
  "phpunit.phpunit": "bin/phpunit.bat",
  "phpunit.phpExecutablePath": "bin/php.bat",
  // ─── PHP Executable (felixfbecker.php-intellisense si está instalado) ─────
  // Redirige php.exe → wrapper Docker para evitar "php.exe no se reconoce".
  "php.executablePath": "bin/php.bat",
  // ─── Intelephense stubs (PHP 8.4 built-ins explícitos) ────────────────────
  // Los stubs por defecto DEBERÍAN incluirlos, pero se declaran explícitamente
  // para garantizar que Core, superglobals y Reflection estén disponibles.
  "intelephense.stubs": [
    "Core",
    "standard",
    "superglobals",
    "Reflection",
    "apache",
    "bcmath",
    "bz2",
    "calendar",
    "ctype",
    "curl",
    "date",
    "dom",
    "enchant",
    "exif",
    "FFI",
    "fileinfo",
    "filter",
    "fpm",
    "ftp",
    "gd",
    "gettext",
    "gmp",
    "hash",
    "iconv",
    "intl",
    "json",
    "ldap",
    "libxml",
    "mbstring",
    "meta",
    "mysqli",
    "openssl",
    "pcntl",
    "pcre",
    "PDO",
    "pgsql",
    "Phar",
    "posix",
    "readline",
    "regex",
    "session",
    "SimpleXML",
    "snmp",
    "soap",
    "sockets",
    "sodium",
    "SPL",
    "sqlite3",
    "sysvmsg",
    "sysvsem",
    "sysvshm",
    "tokenizer",
    "xml",
    "xmlreader",
    "xmlwriter",
    "xsl",
    "Zend OPcache",
    "zip",
    "zlib"
  ],
  // ─── SonarLint PHP: desactivar reglas con falsos positivos en PHP 8.4 ──────
  // php:S3827 ("Undefined types"): SonarPHP con stubs desactualizados reporta
  // Throwable (PHP 7.0+), Override (PHP 8.3), ReflectionClass, method_exists,
  // $_POST/$_SERVER como "undefined" aunque son PHP built-ins válidos en 8.4.
  "sonarlint.rules": {
    "php:S3827": {
      "level": "off"
    }
  }
}
