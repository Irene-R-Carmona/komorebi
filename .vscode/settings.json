{
  // ─── PHP Built-in Validator ───────────────────────────────────────────────
  // Desactivado: Intelephense provee diagnósticos PHP con su propio LSP.
  // El validador built-in requiere un ejecutable PHP local que no existe en
  // este proyecto (corre 100% en Docker).
  "php.validate.enable": false,
  // ─── Intelephense ─────────────────────────────────────────────────────────
  "intelephense.environment.phpVersion": "8.4",
  // ─── phpcs ────────────────────────────────────────────────────────────────
  // Nota: wongjn.php-sniffer no expande ${workspaceFolder}; usa path relativo
  // para que la extensión lo resuelva internamente via path.join(workspaceRoot, value).
  "phpcs.executablePath": "bin/phpcs.bat",
  // ─── PHPStan ──────────────────────────────────────────────────────────────
  "phpstan.executablePath": "bin/phpstan.bat",
  // ─── PHP CS Fixer ─────────────────────────────────────────────────────────
  "php-cs-fixer.executablePath": "bin/php-cs-fixer.bat",
  // ─── Psalm ────────────────────────────────────────────────────────────────
  "psalm.psalmScriptPath": "bin/psalm.bat",
  // ─── PHPUnit ──────────────────────────────────────────────────────────────
  "phpunit.phpunit": "bin/phpunit.bat",
  "phpunit.phpExecutablePath": "bin/php.bat",
  // ─── PHP Executable (felixfbecker.php-intellisense si está instalado) ─────
  // Redirige php.exe → wrapper Docker para evitar "php.exe no se reconoce".
  "php.executablePath": "bin/php.bat"
}
