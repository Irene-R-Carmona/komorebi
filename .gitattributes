# Normalizar todos los archivos de texto a LF en el repo.
# El proyecto corre en Docker/Linux — los shell scripts DEBEN tener LF.
* text=auto eol=lf

# Forzar LF explícito en archivos críticos para Linux/Docker
*.sh        text eol=lf
*.bash      text eol=lf
Makefile    text eol=lf
Caddyfile   text eol=lf
*.php       text eol=lf
*.sql       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.md        text eol=lf
*.neon      text eol=lf
*.ini       text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
*.ts        text eol=lf
*.js        text eol=lf
*.css       text eol=lf
*.html      text eol=lf

# Archivos de Windows/binarios — no tocar
*.bat       text eol=crlf
*.ps1       text eol=crlf
*.exe       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
