# syntax=docker/dockerfile:1.7

FROM dunglas/frankenphp:1.11.1-php8.4-alpine

WORKDIR /app

COPY docker/php/docker-entrypoint.sh /usr/local/bin/docker-entrypoint

RUN install-php-extensions \
    pdo_mysql \
    mbstring \
    intl \
    gd \
    zip \
    bcmath \
    exif \
    redis \
    pcntl \
    xdebug \
    && apk add --no-cache nodejs npm unzip git bash ca-certificates dos2unix \
    && dos2unix /usr/local/bin/docker-entrypoint || true \
    && chmod +x /usr/local/bin/docker-entrypoint || true

# Composer desde imagen oficial (sin ejecutar código remoto sin verificar)
COPY --from=composer:2.8 /usr/bin/composer /usr/bin/composer

COPY docker/php/ini/php.ini /usr/local/etc/php/conf.d/00-php.ini
COPY docker/php/ini/error-dev.ini /usr/local/etc/php/conf.d/01-error.ini
COPY docker/php/ini/uploads.ini /usr/local/etc/php/conf.d/02-uploads.ini
COPY docker/php/ini/memory.ini /usr/local/etc/php/conf.d/03-memory.ini
COPY docker/php/ini/memory-dev.ini /usr/local/etc/php/conf.d/05-memory-dev.ini
COPY docker/php/ini/opcache-dev.ini /usr/local/etc/php/conf.d/06-opcache.ini

# Xdebug desactivado por defecto; para activarlo: make xdebug-on
ARG XDEBUG_ENABLE=false
COPY docker/php/ini/xdebug.ini /tmp/xdebug.ini
COPY docker/php/ini/xdebug-disabled.ini /tmp/xdebug-disabled.ini
RUN if [ "$XDEBUG_ENABLE" = "true" ]; then \
    cp /tmp/xdebug.ini /usr/local/etc/php/conf.d/04-xdebug.ini; \
    else \
    cp /tmp/xdebug-disabled.ini /usr/local/etc/php/conf.d/04-xdebug.ini; \
    fi \
    && rm /tmp/xdebug.ini /tmp/xdebug-disabled.ini

COPY frankenphp.Caddyfile /app/frankenphp.Caddyfile

# Crear directorio de storage antes de cambiar usuario
RUN mkdir -p /app/storage/logs /app/storage/cache /app/storage/uploads \
    && chown -R www-data:www-data /app/storage

USER www-data

EXPOSE 80

ENTRYPOINT ["docker-entrypoint"]
CMD ["frankenphp", "run", "--config=/app/frankenphp.Caddyfile"]
