# =============================================================================
# .env.railway.example — Variables de entorno para Railway.app
# =============================================================================
#
# INSTRUCCIONES:
#   1. Copia estas variables en el Dashboard de Railway:
#      Service > Variables > Raw Editor
#   2. Sustituye TODOS los valores marcados con <CAMBIAR> o <GENERAR>
#   3. Las variables con ${{Plugin.VAR}} se resuelven automáticamente
#      si tienes el plugin MySQL y Redis añadidos al proyecto en Railway.
#
# GENERAR SECRETOS:
#   php bin/generate-secrets.php --show-only
#
# NO commitear este archivo con valores reales rellenos.
# =============================================================================

# --- APLICACION ---
APP_ENV=production
APP_DEBUG=false
APP_URL=https://<tu-subdominio>.up.railway.app
APP_KEY=<GENERAR: php bin/generate-secrets.php --show-only>
APP_TIMEZONE=Europe/Madrid
APP_BUSINESS_TIMEZONE=Asia/Tokyo
APP_VERSION=1.0.0
APP_HTTPS=true

# --- FEATURE FLAGS ---
FEATURE_OPS=1
FEATURE_BACKOFFICE=1
FEATURE_KEEPER=1

# --- DATABASE (Plugin MySQL de Railway) ---
# Railway expone MYSQL_URL automáticamente cuando añades el plugin MySQL.
# health.php y Database::init() leen MYSQL_URL como estrategia primaria.
# Si prefieres variables individuales, descomenta el bloque DB_* y borra MYSQL_URL.
MYSQL_URL=${{MySQL.MYSQL_URL}}

# Alternativa: variables individuales (comentar MYSQL_URL si se usan estas)
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_DATABASE=${{MySQL.MYSQLDATABASE}}
# DB_USERNAME=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SSL_CA=

# --- CACHE & SESSION (Plugin Redis de Railway) ---
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_PASSWORD=${{Redis.REDISPASSWORD}}
REDIS_DB=0
CACHE_TTL=3600
SESSION_DRIVER=redis
CACHE_DRIVER=redis

# --- SEGURIDAD ---
# Genera los tres con: php bin/generate-secrets.php --show-only
SESSION_SECRET=<GENERAR>
CSRF_TOKEN_SECRET=<GENERAR>
ENCRYPTION_KEY=<GENERAR>
SESSION_NAME=KOMOREBI_SESSION
SESSION_LIFETIME=7200
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax

# --- MAIL (Gmail SMTP con App Password) ---
# PREREQUISITO: tener Verificación en 2 pasos activa en la cuenta Google.
# Generar App Password: myaccount.google.com → Seguridad → Contraseñas de aplicación
# El FROM_ADDRESS debe ser el mismo Gmail que el USERNAME.
# El nombre visible para el destinatario será MAIL_FROM_NAME (ej: "Komorebi Cafe").
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<CAMBIAR: tu@gmail.com>
MAIL_PASSWORD=<CAMBIAR: app-password-16-caracteres-sin-espacios>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=<CAMBIAR: tu@gmail.com>
MAIL_FROM_NAME=Komorebi Cafe

# --- TELEGRAM BOT (Opcional) ---
# TELEGRAM_BOT_TOKEN: token del bot (BotFather → /newbot)
# TELEGRAM_CHAT_ID: ID del chat/grupo donde el bot envía alertas críticas
#   Obtenerlo: enviar un mensaje al bot y llamar a https://api.telegram.org/bot<TOKEN>/getUpdates
# Sin estas dos variables configuradas el bot queda silencioso (no falla)
TELEGRAM_BOT_TOKEN=<CAMBIAR o dejar vacío si no se usa>
TELEGRAM_CHAT_ID=<CAMBIAR: ID numérico del chat, ej: -100123456789>
# TELEGRAM_WEBHOOK_URL: referencia para registro futuro del webhook (no leída por la app actualmente)
# TELEGRAM_WEBHOOK_URL=https://<tu-subdominio>.up.railway.app/api/v1/telegram/webhook

# --- API INTEGRACIONES (sin clave, gratis) ---
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_CACHE_TTL=3600
NAGER_DATE_BASE_URL=https://date.nager.at/api/v3
NAGER_DATE_CACHE_TTL=86400

# --- CORS (API pública /api/v1/*) ---
# Orígenes permitidos para peticiones cross-origin, separados por coma.
# Por defecto: http://localhost:8080 (incorrecto para producción).
# Si la API solo se consume desde el mismo dominio Railway, no es crítico,
# pero es necesario si algún cliente externo (app móvil, iframe) llama a la API.
CORS_ALLOWED_ORIGINS=https://<tu-subdominio>.up.railway.app
# CORS_CREDENTIALS=false
# CORS_MAX_AGE=7200

# --- OBSERVABILIDAD ---
SENTRY_DSN=<CAMBIAR o dejar vacío>
# Obtener en: https://sentry.io → Project → Settings → Client Keys (DSN)
# REGENERAR si el DSN fue expuesto en capturas de pantalla o logs

# --- CLOUDINARY ---
# Obtener en: https://console.cloudinary.com → Settings → Access Keys
# Necesario para avatares de usuarios, fotos de animales y facturas en PDF
CLOUDINARY_CLOUD_NAME=<CAMBIAR: tu_cloud_name>
CLOUDINARY_API_KEY=<CAMBIAR: tu_api_key>
CLOUDINARY_API_SECRET=<CAMBIAR: tu_api_secret>

# --- DESPLIEGUE ---
# Railway ejecuta el releaseCommand antes de arrancar el contenedor.
# apply-db.php con --force aplica las migraciones pendientes.
# No es necesario tocar estas variables; están controladas por railway.json/toml.
SKIP_COMPOSER=1
SKIP_MIGRATIONS=1

# --- LOGGING ---
LOG_CHANNEL=single
LOG_LEVEL=warning
LOG_MAX_FILES=7
