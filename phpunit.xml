<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/13.0/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         executionOrder="depends,defects"
         requireCoverageMetadata="false"
         beStrictAboutCoverageMetadata="true"
         failOnRisky="false"
         failOnWarning="true">

    <!-- Test Suites -->
    <testsuites>
        <testsuite name="Unit Tests">
            <directory>tests/Unit</directory>
        </testsuite>

        <testsuite name="Integration Tests">
            <directory>tests/Integration</directory>
        </testsuite>
    </testsuites>

    <!-- Code Coverage -->
    <source>
        <include>
            <directory suffix=".php">app/Core</directory>
            <directory suffix=".php">app/Domain</directory>
            <directory suffix=".php">app/Events</directory>
            <directory suffix=".php">app/Http/Controllers</directory>
            <directory suffix=".php">app/Jobs</directory>
            <directory suffix=".php">app/Listeners</directory>
            <directory suffix=".php">app/Middleware</directory>
            <directory suffix=".php">app/Models</directory>
            <directory suffix=".php">app/Repositories</directory>
            <directory suffix=".php">app/Services</directory>
        </include>

        <exclude>
            <directory>app/Views</directory>
            <file>app/routes.php</file>
        </exclude>
    </source>

    <!-- Coverage Reports (umbrales visuales: líneas ≥15%, métodos ≥18%) -->
    <coverage>
        <report>
            <text outputFile="php://stdout" showOnlySummary="true"/>
            <clover outputFile="tests/reports/coverage.xml"/>
            <html outputDirectory="tests/reports/coverage/"
                  lowUpperBound="50"
                  highLowerBound="70"/>
        </report>
    </coverage>

    <!-- Logging -->
    <logging>
        <testdoxHtml outputFile="tests/reports/testdox.html"/>
        <junit outputFile="tests/reports/junit.xml"/>
    </logging>

    <!-- PHP Settings -->
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="testing-key-for-phpunit-32chars!!" force="true"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_DATABASE" value="komorebi_test" force="true"/>
        <env name="DB_USERNAME" value="root" force="true"/>
        <env name="DB_PASSWORD" value="root" force="true"/>
        <env name="RUN_INTEGRATION_TESTS" value="1"/>
        <env name="REDIS_HOST" value="127.0.0.1"/>
        <env name="REDIS_PORT" value="6379"/>
    </php>
</phpunit>
