{
  "name": "komorebi",
  "scripts": {
    "build:charts": "esbuild public/js/chart-bundle.js --bundle --minify --outfile=public/js/charts.min.js --format=iife --global-name=ChartBundle",
    "test:e2e": "playwright test tests/e2e",
    "test:a11y": "playwright test tests/e2e/accessibility",
    "lighthouse": "lighthouse http://localhost:8080/ --chrome-flags='--no-sandbox --disable-dev-shm-usage' --output=html --output-path=./lighthouse-reports/home.html"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.58.2",
    "chart.js": "^4.4.1",
    "esbuild": "^0.28",
    "eslint": "^9.0.0",
    "lighthouse": "^13.1.0",
    "prettier": "^3.0.0"
  }
}
