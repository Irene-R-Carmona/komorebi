# Environment
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.development
.env.test

# Dependencies
vendor/
node_modules/

# Runtime
storage/logs/*.log
!storage/logs/.gitkeep
storage/cache/*
!storage/cache/.gitkeep
storage/uploads/*
!storage/uploads/.gitkeep
storage/invoices/*
!storage/invoices/.gitkeep
bootstrap/cache/*
!bootstrap/cache/.gitkeep

# Logs genéricos (fuera de storage/)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporales
*.tmp
*.temp

# IDE — VS Code
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json

# IDE — JetBrains (PhpStorm)
.idea/
# Ignorar todo .idea/ excepto configuraciones de proyecto reutilizables
# Si quieres compartir run configs: git add -f .idea/runConfigurations/

# Editores varios
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Testing
.phpunit.result.cache
.phpunit.cache/
tests/reports/
coverage/
playwright-report/
test-results/
# screenshots/ de test automation (Playwright, etc.)
# NOTA: screenshots/ de documentación ya comprometidas se trackean con git add -f
screenshots/
.lighthouseci/
.playwright/
.playwright-mcp/

# Build artifacts
public/build/
public/hot

# Quality tools cache
.php-cs-fixer.cache
.psalm/cache/
.sonarqube/
.quality/baselines/

# Security — Keys & Certs
secrets/
*.pem
*.key
*.crt
*.cert
*.cer
*.p12
*.pfx
*.jks
auth.json
*.token
*.secret
*.secrets

# Database dumps
backups/
*.sql.gz
*.dump
*.bak
docker/mysql/data/
docker/redis/data/

# Docker — archivos de datos locales (volúmenes)
docker/mysql/init-local/
docker/redis/dump.rdb

# Claude Code — configuración local del agente (no compartir)
.claude/

# Logs de desarrollo sueltos en raíz
logs.txt

