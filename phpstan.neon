# ──────────────────────────────────────────────────────────────
#  PHPStan — Configuración
#  Docs: https://phpstan.org/config-reference
# ──────────────────────────────────────────────────────────────

includes:
    - phpstan-baseline.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon

parameters:

    # ── Nivel de análisis ──────────────────────────────────────
    level: 5

    # ── Rutas a analizar ───────────────────────────────────────
    paths:
        - app
        - scripts
        - tests

    # ── Rutas excluidas ────────────────────────────────────────
    excludePaths:
        - vendor
        - node_modules
        - storage
        - cache
        - tmp
        - tests/fixtures

    # ── PHP objetivo ───────────────────────────────────────────
    phpVersion: 80400  # PHP 8.4

    # ── Carga de stubs / bootstrap ─────────────────────────────
    bootstrapFiles:
        - vendor/autoload.php
        - tools/phpstan-bootstrap.php

    # scanFiles:
    #     - config/constants.php

    # scanDirectories:
    #     - src

    # ── Tratamiento de errores ─────────────────────────────────
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: true

services:
    -
        class: App\Tools\PHPStan\LoggerContextRule
        tags:
            - phpstan.rules.rule
