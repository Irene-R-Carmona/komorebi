# ──────────────────────────────────────────────────────────────
#  PHPStan — Configuración
#  Docs: https://phpstan.org/config-reference
# ──────────────────────────────────────────────────────────────

includes:
    - phpstan-baseline.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon

parameters:

    # ── Nivel de análisis ──────────────────────────────────────
    level: 5

    # ── Rutas a analizar ───────────────────────────────────────
    paths:
        - app
        - scripts
        - tests

    # ── Rutas excluidas ────────────────────────────────────────
    excludePaths:
        - vendor
        - storage

    # ── PHP objetivo ───────────────────────────────────────────
    phpVersion: 80400  # PHP 8.4

    # ── Carga de stubs / bootstrap ─────────────────────────────
    bootstrapFiles:
        - vendor/autoload.php
        - tools/phpstan-bootstrap.php

    # scanFiles:
    #     - config/constants.php

    # scanDirectories:
    #     - src

    # ── Tratamiento de errores ─────────────────────────────────
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: true

    # ── Supresiones globales justificadas ──────────────────────
    ignoreErrors:
        # El patrón de controladores usa ?ResponseInterface como contrato
        # de todos los métodos de acción (AGENTS.md). Los métodos que renderizan
        # vistas llaman View::render() y devuelven null; los que redirigen devuelven
        # ResponseInterface. PHPStan detecta que la mitad del union nunca se usa,
        # pero es in tentional por diseño de framework.
        -
            identifier: return.unusedType
            paths:
                - app/Http/Controllers/**

        # En tests, assertInstanceOf/assertTrue/assertSame se usan para documentar
        # el tipo esperado aunque PHPStan ya lo haya inferido. PHPUnit 10 no tiene
        # anotaciones de tipo en los stubs que eviten este falso positivo.
        -
            identifier: method.alreadyNarrowedType
            paths:
                - tests/**

        # En tests de existencia de métodos/funciones se usa method_exists() /
        # is_callable() sobre clases concretas conocidas para documentar la API
        # pública. PHPStan los detecta como redundantes pero son intencionales.
        -
            identifier: function.alreadyNarrowedType
            paths:
                - tests/**

        # PHPUnit InvocationStubber::with() y PDO::method() no están anotados
        # con stubs completos en phpstan-phpunit; los encadenados de mocks generan
        # method.notFound aunque el código funciona correctamente en runtime.
        -
            identifier: method.notFound
            paths:
                - tests/**

        # Varios tests de servicios definen un stub local `class PDO extends \PDO`
        # en su propio namespace (Tests\Unit\Services). PHPStan no resuelve la clase
        # porque no está registrada en el autoloader; es un helper de test en-línea.
        -
            identifier: class.notFound
            paths:
                - tests/**

        # Las propiedades de tipo Tests\Unit\Services\PDO que almacenan stubs de
        # PHPUnit tienen docblocks `PDO&Stub` que divergen del tipo nativo declarado.
        -
            identifier: property.phpDocType
            paths:
                - tests/**

        # Asignaciones de `PDO&Stub` al tipo nativo `Tests\Unit\Services\PDO` en
        # los tests de servicio que usan el stub local de PDO.
        -
            identifier: assign.propertyType
            paths:
                - tests/**

        # Llamadas con arrays parciales a servicios para cubrir rutas de error:
        # los tests pasan datos incompletos de manera deliberada (validación).
        # También cubre la discrepancia Tests\Unit\Services\PDO vs \PDO.
        -
            identifier: argument.type
            paths:
                - tests/**

        # @var con tipo anónimo (FormRequest@anonymous) en test de request;
        # es un artefacto del PHP anonymous class inline, no un error real.
        -
            identifier: varTag.nativeType
            paths:
                - tests/**

        # assertNotEmpty('') y ?? sobre offset potencialmente ausente en tests de
        # middleware — patrones intencionales para documentar comportamiento edge.
        -
            identifier: nullCoalesce.offset
            paths:
                - tests/**
        -
            identifier: method.impossibleType
            paths:
                - tests/**

services:
    -
        class: App\Tools\PHPStan\LoggerContextRule
        tags:
            - phpstan.rules.rule
